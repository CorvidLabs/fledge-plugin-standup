#!/usr/bin/env bash
# fledge-plugin-standup — generate a Markdown standup post from recent commits.
#
# Wraps `fledge ask`, so it inherits whatever AI provider/model the user has
# configured via `fledge ai use`.
set -euo pipefail

SINCE="24 hours ago"
AUTHOR=""
INCLUDE_DIFF=false
RAW=false
SHOW_PROMPT=false

usage() {
  cat <<'EOF'
fledge standup — Markdown standup summary from recent git activity

USAGE:
  fledge standup [OPTIONS]

OPTIONS:
  --since <SPEC>      Time window for commits (default: "24 hours ago").
                      Anything `git log --since` accepts: "1 week ago",
                      "yesterday", "2026-04-20", etc.
  --author <NAME>     Filter to a specific author (default: current git user)
  --include-diff      Include diff stats in the model's context (slower, richer)
  --raw               Skip the AI step — print the raw `git log` output
  --show-prompt       Print the prompt that was sent (debug)
  -h, --help          Show this help

EXAMPLES:
  fledge standup                          # last 24h, current user, narrated
  fledge standup --since "1 week ago"     # weekly recap
  fledge standup --author "Leif"
  fledge standup --since yesterday --include-diff
  fledge standup --raw                    # plain log, no LLM
  fledge standup -- --provider ollama     # forward provider/model to `ask`
EOF
}

ASK_PASSTHROUGH=()
while [ $# -gt 0 ]; do
  case "$1" in
    --since)        SINCE="${2:?--since needs a value}"; shift 2 ;;
    --since=*)      SINCE="${1#*=}"; shift ;;
    --author)       AUTHOR="${2:?--author needs a value}"; shift 2 ;;
    --author=*)     AUTHOR="${1#*=}"; shift ;;
    --include-diff) INCLUDE_DIFF=true; shift ;;
    --raw)          RAW=true; shift ;;
    --show-prompt)  SHOW_PROMPT=true; shift ;;
    -h|--help)      usage; exit 0 ;;
    --)             shift; ASK_PASSTHROUGH=("$@"); break ;;
    *)
      echo "fledge standup: unexpected argument '$1'" >&2
      exit 64
      ;;
  esac
done

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "fledge standup: not inside a git repository." >&2
  exit 65
fi

# Default author to the current git user if --author wasn't specified.
if [ -z "$AUTHOR" ]; then
  AUTHOR="$(git config user.name 2>/dev/null || true)"
fi

# Build the git log args carefully — avoid eval on user input.
LOG_ARGS=(log --since="$SINCE" --pretty=format:'%h  %s')
if [ -n "$AUTHOR" ]; then
  LOG_ARGS+=(--author="$AUTHOR")
fi

LOG="$(git "${LOG_ARGS[@]}" || true)"

if [ -z "$LOG" ]; then
  if [ -n "$AUTHOR" ]; then
    echo "fledge standup: no commits by '$AUTHOR' since '$SINCE'." >&2
  else
    echo "fledge standup: no commits since '$SINCE'." >&2
  fi
  exit 0
fi

if [ "$RAW" = "true" ]; then
  echo "$LOG"
  exit 0
fi

# Diff stats are optional — they give the model more to work with at the cost
# of context tokens. Cap at 500 lines.
DIFF_STATS=""
if [ "$INCLUDE_DIFF" = "true" ]; then
  STAT_ARGS=(log --since="$SINCE" --shortstat --pretty=format:'%h')
  if [ -n "$AUTHOR" ]; then
    STAT_ARGS+=(--author="$AUTHOR")
  fi
  DIFF_STATS="$(git "${STAT_ARGS[@]}" 2>/dev/null | head -500 || true)"
fi

REPO_NAME="$(basename "$(git rev-parse --show-toplevel 2>/dev/null || echo project)")"

PROMPT="You are turning a list of git commits into a concise, paste-ready Markdown standup post for a team channel.

Output exactly three sections, in this order, using these headers verbatim:
  ## Yesterday
  ## Today
  ## Blockers

Rules:
- \"Yesterday\" — what was actually done. Write 3–6 bullet points grouped by theme. Use commit subjects but rewrite them in the past tense and strip conventional-commit prefixes (feat:, fix:, etc.).
- \"Today\" — make 1–3 plausible next-step bullets inferred from the commits. Mark them as inferences with a leading \"(inferred)\" so the reader can edit.
- \"Blockers\" — write \"None\" unless the commits clearly indicate one (e.g. a 'wip:' or 'blocked:' subject). No speculation.
- No preamble. No trailing summary. Just the three sections.
- Total length: 10 lines or fewer.

Repo: $REPO_NAME
Window: since $SINCE${AUTHOR:+ (author: $AUTHOR)}

Commits:
$LOG"

if [ "$INCLUDE_DIFF" = "true" ] && [ -n "$DIFF_STATS" ]; then
  PROMPT="$PROMPT

Diff stats (per commit):
$DIFF_STATS"
fi

if [ "$SHOW_PROMPT" = "true" ]; then
  echo "--- prompt ---"
  echo "$PROMPT"
  echo "--- end prompt ---"
  echo
fi

exec fledge ask --no-spec-index "$PROMPT" "${ASK_PASSTHROUGH[@]}"
